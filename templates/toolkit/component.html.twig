{% extends 'base.html.twig' %}

{% set title = 'Component ' ~ component.manifest.name ~ ' - ' ~ kit.manifest.name ~ ' Kit' %}
{% set description = "Documentation of component #{component.manifest.name}, from the UX Toolkit #{kit.manifest.name}, #{kit.manifest.description}." %}
{% set meta = {
    title: title,
    description: description,
    canonical: url('app_icons'),
    social: {
        title: title,
        description: description,
        image: {
            url: absolute_url(asset(package.getSocialImage('1200x675'))),
            type: 'image/png',
            width: 1200,
            height: 675,
            alt: package.humanName ~ ' - Kit ' ~ kit.manifest.name,
        },
    },
} %}

{% block content %}
    <div class="hero"></div>

    <div class="max-w-[1140px] mx-auto lg:pt-6 grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-8 px-4 lg:px-0">
        <div class="hidden lg:block">
            {{ include('toolkit/_kit_aside.html.twig') }}
        </div>

        <div class="min-w-0">
            <div class="xl:hidden sticky top-0 z-9 -mx-4 mb-6 px-4 py-3 bg-body/85 backdrop-blur border-b border-border flex items-center gap-3">
                <div data-controller="disclosure" data-disclosure-lock-body-value="true" data-disclosure-portal-value="true" class="lg:hidden">
                    <button type="button"
                            data-action="disclosure#toggle"
                            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-border text-sm hover:bg-surface"
                            aria-expanded="false"
                            aria-controls="kit-drawer-panel"
                            aria-label="Open menu">
                        <twig:ux:icon name="lucide:panel-left" class="size-4" />
                        Menu
                    </button>

                    <div data-disclosure-target="panel"
                         id="kit-drawer-panel"
                         role="dialog"
                         aria-modal="true"
                         aria-label="Menu"
                         class="hidden fixed inset-0 z-30">
                        <div class="absolute inset-0 bg-black/50 backdrop-blur opacity-0 transition-opacity duration-200 ease-out [.is-open_&]:opacity-100" data-action="click->disclosure#close"></div>
                        <aside class="absolute inset-y-0 left-0 w-72 bg-body border-r border-border shadow-xl flex flex-col -translate-x-full transition-transform duration-250 ease-out [.is-open_&]:translate-x-0">
                            <div class="flex items-center justify-between p-4 border-b border-border">
                                <strong class="text-sm font-semibold">Menu</strong>
                                <button type="button" data-action="disclosure#close" aria-label="Close" class="p-1 rounded hover:bg-surface">
                                    <twig:ux:icon name="lucide:x" class="size-4" />
                                </button>
                            </div>
                            <div class="overflow-y-auto flex-1 p-4">
                                {{ include('toolkit/_kit_aside_content.html.twig') }}
                            </div>
                        </aside>
                    </div>
                </div>

                <div data-controller="disclosure" data-disclosure-transition-duration-value="150" class="ml-auto relative">
                    <button type="button"
                            data-action="disclosure#toggle"
                            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-md border border-border text-sm hover:bg-surface"
                            aria-expanded="false"
                            aria-controls="toc-popover-panel"
                            aria-label="Open table of contents">
                        On this page
                        <twig:ux:icon name="lucide:chevron-down" class="size-4" />
                    </button>

                    <nav data-disclosure-target="panel"
                         id="toc-popover-panel"
                         class="hidden absolute right-0 top-full mt-2 w-72 max-h-[60vh] overflow-y-auto bg-subtle border border-border rounded-lg shadow-lg p-3 text-sm z-20 opacity-0 -translate-y-1 transition duration-150 ease-out [&.is-open]:opacity-100 [&.is-open]:translate-y-0"
                         aria-label="On this page">
                        {% if toc_items|length > 0 %}
                            <ul class="list-unstyled space-y-1">
                                {% for item in toc_items %}
                                    {% set class = item.level == 3 ? 'ml-2' %}
                                    <li class="rounded transition-colors duration-100 ease-in-out hover:bg-surface {{ class }}">
                                        <a href="#{{ item.id }}" class="block px-2 py-0.5 text-[.9rem]" data-action="click->disclosure#close">
                                            {{ item.title|raw }}
                                        </a>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p class="px-2 py-1 text-foreground/60">No headings on this page.</p>
                        {% endif %}
                    </nav>
                </div>
            </div>

            <twig:Toolkit:Breadcrumb class="mb-2">
                <twig:Toolkit:Breadcrumb:Item>
                    <twig:Toolkit:Breadcrumb:Link href="{{ path('app_toolkit') }}">UX Toolkit</twig:Toolkit:Breadcrumb:Link>
                </twig:Toolkit:Breadcrumb:Item>
                <twig:Toolkit:Breadcrumb:Separator />
                <twig:Toolkit:Breadcrumb:Item>
                    <twig:Toolkit:Breadcrumb:Link href="{{ path('app_toolkit', {_fragment: 'kits'}) }}">Kits</twig:Toolkit:Breadcrumb:Link>
                </twig:Toolkit:Breadcrumb:Item>
                <twig:Toolkit:Breadcrumb:Separator />
                <twig:Toolkit:Breadcrumb:Item>
                    <twig:Toolkit:Breadcrumb:Link href="{{ path('app_toolkit_kit', {kitId: kit_id.value}) }}">{{ kit.manifest.name }}</twig:Toolkit:Breadcrumb:Link>
                </twig:Toolkit:Breadcrumb:Item>
                <twig:Toolkit:Breadcrumb:Separator />
                <twig:Toolkit:Breadcrumb:Item active>
                    {{ component.manifest.name }}
                </twig:Toolkit:Breadcrumb:Item>
            </twig:Toolkit:Breadcrumb>

            <twig:Toolkit:ComponentDoc kitId="{{ kit_id }}" component="{{ component }}" tocItems="{{ toc_items }}" />
        </div>
    </div>
{% endblock %}
