<div class="flex gap-8 items-start">
    <div class="flex-1 min-w-0 Wysiwyg">
        {# The recipe README owns the page title (its `# ` heading), so we render no chrome <h1>
           here. The "View as Markdown" link floats to the top-right, beside that title. #}
        <a
            href="{{ path('app_toolkit_component', {kitId: kitId, componentName: component.name}) }}.md"
            class="float-right ml-4 mt-1 inline-flex items-center gap-2 text-sm text-foreground/80 no-underline hover:underline underline-offset-4 shrink-0"
            title="View this page as Markdown (useful for LLMs)"
        >
            <twig:ux:icon name="material-symbols:markdown-outline" class="size-6" />
            <span>View as Markdown</span>
        </a>

        {{ this.htmlContent|raw }}
    </div>

    {% if tocItems %}
        <nav data-controller="toolkit-recipe-toc"
             class="hidden xl:block w-52 shrink-0 sticky top-4 max-h-[calc(100vh-2rem)] overflow-y-auto text-sm" aria-label="On this page">
            <strong class="font-semibold px-2 mb-2 text-foreground block">On this page</strong>
            <ul class="list-unstyled space-y-1">
                {% for item in tocItems %}
                    {% set class = item.level == 3 ? 'ml-2' %}
                    <li
                        class="rounded transition-colors duration-100 ease-in-out hover:bg-surface [&.active]:bg-surface {{ class }}"
                        data-toolkit-recipe-toc-target="link"
                    >
                        <a href="#{{ item.id }}" class="block px-2 py-0.5 text-[.9rem]">
                            {{ item.title|raw }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}
</div>
