{#-
    Presentational form input. Framework-agnostic: bind via `data-model` in
    LiveComponent forms, or fed by the form theme via the field_* helpers.
-#}
{%- props type = 'text', name = null, id = null, value = null, hasError = false -%}
<input
    type="{{ type }}"
    {%- if name is not null %} name="{{ name }}"{% endif %}
    {%- if id is not null %} id="{{ id }}"{% endif %}
    {%- if value is not null and value is not same as('') %} value="{{ value }}"{% endif %}
    class="{{ ('w-full bg-body border rounded-md px-3 py-1.5' ~ (hasError ? ' border-red-500 dark:border-red-400') ~ ' ' ~ attributes.render('class'))|tailwind_merge }}"
    {{- attributes.without('class') }}
>
