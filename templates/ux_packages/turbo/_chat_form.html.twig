
<twig:Form:Select aria-label="Choose a message" name="chat_message" class="py-2">
    <option value="">Choose a message</option>
    {% for key, message in messageChoices %}
        <option value="{{ key }}">{{ message }}</option>
    {% endfor %}
</twig:Form:Select>

<twig:Button variant="dark" type="submit" class="mt-3 w-full">Chat!</twig:Button>
