{#
    Site button. Renders an <a> when `href` is set, otherwise a <button>.

    Variants are added as the migration needs them (Phase 9):
    - outline: ex Bootstrap `.btn-outline-primary` (neutral, transparent, fills on hover)
    - dark:    ex Bootstrap `.btn-dark` (solid near-black)
#}
{%- props href = null, variant = 'outline', size = 'md' -%}
{%- set style = html_cva(
    base: 'inline-flex items-center justify-center gap-2 rounded-md border cursor-pointer transition duration-150 ease-in-out',
    variants: {
        variant: {
            outline: 'border-body-text text-body-text bg-transparent opacity-75 hover:opacity-100 hover:bg-body-text hover:text-body',
            dark: 'border-[#212529] bg-[#212529] text-white hover:opacity-90',
        },
        size: {
            sm: 'px-2.5 py-1 text-sm',
            md: 'px-3 py-1.5 text-base',
        },
    },
) -%}
{%- set classes = style.apply({ variant: variant, size: size }, attributes.render('class'))|tailwind_merge -%}
{%- set tag = href ? 'a' : 'button' -%}

<{{ tag }}
    class="{{ classes }}"
    {%- if href %} href="{{ href }}"{% endif %}
    {{ attributes.defaults(href ? {} : { type: 'button' }).without('class') }}
>{% block content %}{% endblock %}</{{ tag }}>
