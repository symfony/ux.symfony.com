{% extends 'ux_packages/package.html.twig' %}

{% block body %}
    <h1>Add a TODO Item</h1>

    {{ include('ux_packages/turbo/_demo_message.html.twig') }}

    <turbo-frame id="daily-todos">
        <a href="{{ path('app_turbo_todo_list') }}"><twig:ux:icon name="arrow-left" /> Back to list</a>
        <form class="mt-6" action="{{ path('app_turbo_add_todo_item') }}" method="POST" novalidate>
            {{ form_row(form.item, {
                attr: {
                    placeholder: 'Go on a run... to the donut shop',
                    autofocus: true,
                },
            }) }}

            <twig:Button variant="dark" type="submit" class="mt-6 w-full">Create!</twig:Button>
        </form>
    </turbo-frame>
{% endblock %}
