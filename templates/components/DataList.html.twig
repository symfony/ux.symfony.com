{% props items, itemClass = '' %}

<dl class="flex flex-row flex-wrap justify-center content-center gap-6">
    {% for label, value in items %}
        {% if value is not null %}
            <twig:Code:Snippet class="flex items-center gap-4 {{ itemClass }}">
                <dt class="font-bold after:content-[':']">{{ label }}</dt>
                <dd class="text-code font-normal m-0 Wysiwyg">
                    {%- if value.href|default %}
                        <a href="{{ value.href }}">{{ value.title }}</a>
                    {% else -%}
                        {{ value.title ?? value }}
                    {%- endif -%}
                </dd>
            </twig:Code:Snippet>
        {% endif %}
    {% endfor %}
</dl>
