<div class="relative">
    <div data-loader class="absolute flex items-center justify-center gap-1 w-full" style="height: {{ height }};">
        <svg width="18" height="18" viewBox="0 0 24 24" class="animate-spin">
            <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 1 1-6.219-8.56"/>
        </svg>
        <span>Loading...</span>
    </div>
    <a href="{{ previewUrl }}" target="_blank" rel="noopener" class="absolute top-2 right-2 z-10 inline-flex items-center justify-center size-8 rounded-md bg-background/80 border border-border text-muted-foreground hover:text-foreground hover:bg-background transition-colors" title="Open in a new tab">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
    </a>
    <iframe
        class="w-full transition-opacity duration-250 rounded-xl data-loading:opacity-0"
        src="{{ previewUrl }}"
        loading="lazy"
        data-loading
        style="height: {{ height }};"
        onload="this.closest('.relative').querySelector('[data-loader]').style.display = 'none'; this.removeAttribute('data-loading')"
    ></iframe>
</div>
