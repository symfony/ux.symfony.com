{% extends 'ux_packages/package.html.twig' %}

{% block package_header %}
    {% component PackageHeader with {
        package: 'twig-component',
        eyebrowText: 'Object-Oriented Templates',
    } %}
        {% block title_header %}
            PHP Classes that render: <em>Twig Components</em>
        {% endblock %}

        {% block sub_content %}
            Create reusable, object-oriented templates. PHP class + template = Twig components.
        {% endblock %}
    {% endcomponent %}
{% endblock %}

{# Alert is an anonymous component (template only), so a single code block is enough. #}
{% block package_code_blocks %}
    <div class="mb-12">
        <twig:CodeBlock filename="templates/components/Alert.html.twig" height="330px" />
    </div>
{% endblock %}

{% block demo_title %}UX Twig Components{% endblock %}

{% block demo_content %}
    <div class="grid grid-cols-12 gap-x-6">
        <div class="col-span-6">
            <twig:CodeBlock
                filename="templates/ux_packages/twig_component.html.twig"
                :showFilename="false"
                targetTwigBlock="alert_default_example"
                :showTwigExtends="false"
                height="auto"
            />
        </div>
        <div class="col-span-6">
            {% block alert_default_example %}
                <twig:Alert>
                    No variant set, so the alert falls back to the neutral "info" style.
                </twig:Alert>
            {% endblock %}
        </div>
    </div>

    <div class="grid grid-cols-12 gap-x-6 my-2">
        <div class="col-span-6">
            <twig:CodeBlock
                filename="templates/ux_packages/twig_component.html.twig"
                :showFilename="false"
                targetTwigBlock="alert_success_example"
                :showTwigExtends="false"
                height="auto"
            />
        </div>
        <div class="col-span-6">
            {% block alert_success_example %}
                <twig:Alert variant="success">
                    Your changes were saved.
                </twig:Alert>
            {% endblock %}
        </div>
    </div>

    <div class="grid grid-cols-12 gap-x-6 my-2">
        <div class="col-span-6">
            <twig:CodeBlock
                filename="templates/ux_packages/twig_component.html.twig"
                :showFilename="false"
                targetTwigBlock="alert_warning_example"
                :showTwigExtends="false"
                height="auto"
            />
        </div>
        <div class="col-span-6">
            {% block alert_warning_example %}
                <twig:Alert variant="warning">
                    Your session will expire in a few minutes.
                </twig:Alert>
            {% endblock %}
        </div>
    </div>

    <div class="grid grid-cols-12 gap-x-6 my-2">
        <div class="col-span-6">
            <twig:CodeBlock
                filename="templates/ux_packages/twig_component.html.twig"
                :showFilename="false"
                targetTwigBlock="alert_danger_example"
                :showTwigExtends="false"
                height="auto"
            />
        </div>
        <div class="col-span-6">
            {% block alert_danger_example %}
                <twig:Alert variant="danger">
                    Oh no! The dinos escaped!
                </twig:Alert>
            {% endblock %}
        </div>
    </div>
{% endblock %}
