{% extends 'ux_packages/package.html.twig' %}

{% block body %}
    <h1>Today's TODO List!</h1>

    {{ include('ux_packages/turbo/_demo_message.html.twig') }}

    <turbo-frame id="daily-todos">
        <ul class="mb-0">
            {% for key, item in todos %}
                <li>
                    {{ item }}
                    <form class="inline" action="{{ path('app_turbo_remove_todo_item', {
                        id: key,
                    }) }}">
                        <twig:Button variant="link" type="submit" class="p-0" title="All done!"><twig:ux:icon name="circle-check" /></twig:Button>
                    </form>
                </li>
            {% endfor %}
        </ul>

        {% if todos is empty %}
            <div class="rounded-md border border-green-200 bg-green-100 p-4 text-green-800 dark:border-green-900 dark:bg-green-950 dark:text-green-300">You did it! Order a 🍕 and take the afternoon off.</div>
        {% endif %}

        <twig:Button variant="dark" href="{{ path('app_turbo_add_todo_item') }}" class="mt-12 w-full">+ Add another item</twig:Button>
    </turbo-frame>
{% endblock %}
