{#-
    Presentational error list. `errors` accepts null, a single message string,
    or any iterable of messages (e.g. the field_errors() generator).
-#}
{%- props errors = null -%}
{%- if errors is iterable -%}
    {%- set list = errors|map(error => error) -%}
{%- else -%}
    {%- set list = errors is empty ? [] : [errors] -%}
{%- endif -%}
{%- if list is not empty -%}
    <ul class="mt-1 list-none p-0 text-sm text-red-600 dark:text-red-400">
        {%- for error in list -%}
            <li>{{ error }}</li>
        {%- endfor -%}
    </ul>
{%- endif -%}
