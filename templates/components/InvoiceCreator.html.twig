<div {{ attributes }}>
    <form data-action="live#action:prevent" data-live-action-param="saveInvoice">
        <div class="mb-4">
            <twig:Form:Label for="customer-name">Customer name:</twig:Form:Label>
            <twig:Form:Input type="text" id="customer-name" data-model="invoice.customerName" hasError="{{ _errors.has('invoice.customerName') }}" />
            <twig:Form:Errors errors="{{ _errors.get('invoice.customerName') }}" />
        </div>

        <div class="mb-4">
            <twig:Form:Label for="customer-email">Billing Email:</twig:Form:Label>
            <twig:Form:Input type="email" id="customer-email" data-model="invoice.customerEmail" hasError="{{ _errors.has('invoice.customerEmail') }}" />
            <twig:Form:Errors errors="{{ _errors.get('invoice.customerEmail') }}" />
        </div>

        <div class="rounded-md border">
            <div class="border-b px-4 py-2 font-medium">Invoice Items</div>
            <div class="p-4">
                <table class="w-full text-left [&_:is(th,td)]:px-2 [&_:is(th,td)]:py-2 [&_:is(th,td)]:border-b [&_:is(th,td)]:border-border">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th style="width: 100px;">Price</th>
                            <th style="width: 100px;">Quantity</th>
                            <th style="width: 100px;">&nbsp;</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for key, line in lineItems %}
                            <twig:InvoiceCreatorLineItem
                                key="{{ key }}"
                                productId="{{ line.productId }}"
                                quantity="{{ line.quantity }}"
                                isEditing="{{ line.isEditing }}"
                            />
                        {% endfor %}
                    </tbody>
                </table>

                <twig:Button
                    variant="secondary"
                    size="sm"
                    data-action="live#action"
                    data-live-action-param="addLineItem"
                    class="mt-2"
                ><twig:ux:icon name="plus" /> Add Item</twig:Button>
            </div>
        </div>

        <div class="mt-6 ml-auto max-w-xs">
            <table class="w-full text-right [&_:is(th,td)]:px-2 [&_:is(th,td)]:py-2 [&_:is(th,td)]:border-b [&_:is(th,td)]:border-border">
                <tbody>
                    <tr>
                        <th>Subtotal:</th>
                        <td>{{ this.subtotal|format_currency('USD') }}</td>
                    </tr>
                    <tr>
                        <th>Tax rate:</th>
                        <td class="flex justify-end">
                            <div class="flex w-[110px]">
                                <twig:Form:Input type="number" data-model="invoice.taxRate" hasError="{{ _errors.has('invoice.taxRate') }}" class="rounded-l-md rounded-r-none" />
                                <span class="inline-flex items-center border border-l-0 rounded-r-md bg-surface px-2">%</span>
                            </div>
                            <twig:Form:Errors errors="{{ _errors.get('invoice.taxRate') }}" />
                        </td>
                    </tr>
                    <tr>
                        <th>Total:</th>
                        <td>{{ this.total|format_currency('USD') }}</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <twig:Button
            variant="primary"
            :disabled="areAnyLineItemsEditing"
        >
            <span data-loading="action(saveInvoice)|show">
                <twig:ux:icon name="spinner" style="animation: spin 1s linear infinite;" />
            </span>
            {% if savedSuccessfully %}
                <twig:ux:icon name="circle-check" class="text-signal-green" />
            {% endif %}
            {% if saveFailed %}
                <twig:ux:icon name="circle-exclamation" />
            {% endif %}
            Save Invoice
        </twig:Button>
        {% if saveFailed %}
            <small class="text-muted">Check above for errors</small>
        {% endif %}
        {% if areAnyLineItemsEditing %}
            <small class="text-muted">Save all line items before continuing.</small>
        {% endif %}
    </form>
</div>
