{
    "description": "Symfony UX website & demos",
    "license": "proprietary",
    "type": "project",
    "homepage": "https://ux.symfony.com",
    "require": {
        "php": "~8.5.0",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "composer/semver": "^3.4.3",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "intervention/image": "^2.7.2",
        "league/commonmark": "^2.6.0",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/asset": "8.1.*",
        "symfony/asset-mapper": "8.1.*",
        "symfony/console": "8.1.*",
        "symfony/dotenv": "8.1.*",
        "symfony/expression-language": "8.1.*",
        "symfony/flex": "^2.11.0",
        "symfony/form": "8.1.*",
        "symfony/framework-bundle": "8.1.*",
        "symfony/http-client": "8.1.*",
        "symfony/mercure-bundle": "^0.4.2",
        "symfony/monolog-bundle": "^4.0.2",
        "symfony/notifier": "8.1.*",
        "symfony/runtime": "8.1.*",
        "symfony/serializer": "8.1.*",
        "symfony/stimulus-bundle": "3.x-dev",
        "symfony/string": "8.1.*",
        "symfony/translation": "8.1.*",
        "symfony/twig-bundle": "8.1.*",
        "symfony/uid": "8.1.*",
        "symfony/ux-autocomplete": "3.x-dev",
        "symfony/ux-calendar-link": "3.x-dev",
        "symfony/ux-chartjs": "3.x-dev",
        "symfony/ux-cropperjs": "3.x-dev",
        "symfony/ux-dropzone": "3.x-dev",
        "symfony/ux-icons": "3.x-dev",
        "symfony/ux-leaflet-map": "3.x-dev",
        "symfony/ux-live-component": "3.x-dev",
        "symfony/ux-map": "3.x-dev",
        "symfony/ux-native": "3.x-dev",
        "symfony/ux-notify": "3.x-dev",
        "symfony/ux-react": "3.x-dev",
        "symfony/ux-toolkit": "3.x-dev",
        "symfony/ux-translator": "3.x-dev",
        "symfony/ux-turbo": "3.x-dev",
        "symfony/ux-twig-component": "3.x-dev",
        "symfony/ux-vue": "3.x-dev",
        "symfony/validator": "8.1.*",
        "symfony/yaml": "8.1.*",
        "symfonycasts/dynamic-forms": "^0.2.0",
        "symfonycasts/tailwind-bundle": "^0.12.0",
        "tales-from-a-dev/twig-tailwind-extra": "^1.0",
        "tempest/highlight": "^2.11.2",
        "twig/extra-bundle": "^3.24",
        "twig/html-extra": "^3.24",
        "twig/intl-extra": "^3.24",
        "twig/markdown-extra": "^3.24",
        "twig/string-extra": "^3.24",
        "twig/twig": "^3.27.1"
    },
    "require-dev": {
        "kocal/phpstan-symfony-ux": "^1.1",
        "php-cs-fixer/shim": "^3.95.3",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^13.0",
        "playwright-php/playwright": "^1.2",
        "symfony/browser-kit": "8.1.*",
        "symfony/css-selector": "8.1.*",
        "symfony/debug-bundle": "8.1.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/stopwatch": "8.1.*",
        "symfony/web-profiler-bundle": "8.1.*",
        "vincentlanglet/twig-cs-fixer": "^3.11",
        "zenstruck/browser": "^1.10",
        "zenstruck/foundry": "^2.8"
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php84": "*",
        "symfony/polyfill-php85": "*"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true,
        "bump-after-update": true
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "docker": true,
            "require": "8.1.*"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@auto-scripts",
            "@tailwind:build"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@tailwind:build"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "tailwind:build": [
            "@php bin/console tailwind:build --minify assets/styles/app.css",
            "@php bin/console tailwind:build --minify assets/styles/demos/live-memory.css",
            "@php bin/console tailwind:build --minify assets/styles/toolkit-shadcn.css",
            "@php bin/console tailwind:build --minify assets/styles/toolkit-flowbite-4.css"
        ]
    }
}
